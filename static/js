document.addEventListener('DOMContentLoaded', () => {
    // التبديل بين التبويبات
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            tabBtns.forEach(b => b.classList.remove('active'));
            tabContents.forEach(c => c.classList.remove('active'));
            
            btn.classList.add('active');
            document.getElementById(btn.dataset.tab).classList.add('active');
            document.getElementById('resultSection').style.display = 'none';
        });
    });

    // إعداد مناطق الرفع
    setupUploadZone('dropZoneInterpolate', 'fileInterpolate', 'fileInfoInterpolate');
    setupUploadZone('dropZoneSpoof', 'fileSpoof', 'fileInfoSpoof');

    // أزرار المعالجة
    document.getElementById('btnInterpolate').addEventListener('click', () => processVideo('interpolate'));
    document.getElementById('btnSpoof').addEventListener('click', () => processVideo('spoof'));
});

function setupUploadZone(dropZoneId, inputId, infoId) {
    const dropZone = document.getElementById(dropZoneId);
    const input = document.getElementById(inputId);
    const info = document.getElementById(infoId);

    dropZone.addEventListener('click', () => input.click());

    input.addEventListener('change', (e) => {
        if (e.target.files.length > 0) {
            info.textContent = `✅ تم اختيار: ${e.target.files[0].name}`;
        }
    });

    dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        if (e.dataTransfer.files.length > 0) {
            input.files = e.dataTransfer.files;
            info.textContent = `✅ تم اختيار: ${e.dataTransfer.files[0].name}`;
        }
    });
}

async function processVideo(type) {
    const fileInput = document.getElementById(`file${type.charAt(0).toUpperCase() + type.slice(1)}`);
    const file = fileInput.files[0];
    
    if (!file) {
        alert('الرجاء اختيار فيديو أولاً!');
        return;
    }

    const btn = document.getElementById(`btn${type.charAt(0).toUpperCase() + type.slice(1)}`);
    const progressContainer = document.getElementById(`progressContainer${type.charAt(0).toUpperCase() + type.slice(1)}`);
    const progressFill = document.getElementById(`progressFill${type.charAt(0).toUpperCase() + type.slice(1)}`);
    const progressText = document.getElementById(`progressText${type.charAt(0).toUpperCase() + type.slice(1)}`);

    btn.disabled = true;
    progressContainer.style.display = 'block';
    
    // محاكاة شريط التقدم (لأن FFmpeg في a-shell قد يستغرق وقتاً)
    let progress = 0;
    const interval = setInterval(() => {
        progress += Math.random() * 5;
        if (progress > 90) progress = 90;
        progressFill.style.width = `${progress}%`;
    }, 500);

    const formData = new FormData();
    formData.append('video', file);
    
    if (type === 'interpolate') {
        formData.append('target_fps', document.getElementById('targetFpsInterpolate').value);
        formData.append('quality', document.getElementById('qualityInterpolate').value);
    } else {
        formData.append('target_fps', document.getElementById('targetFpsSpoof').value);
        formData.append('method', document.getElementById('methodSpoof').value);
    }

    try {
        const response = await fetch(`/api/process/${type}`, {
            method: 'POST',
            body: formData
        });

        const result = await response.json();
        clearInterval(interval);
        progressFill.style.width = '100%';
        progressText.textContent = 'تمت المعالجة بنجاح!';

        if (result.success) {
            document.getElementById('originalVideo').src = URL.createObjectURL(file);
            document.getElementById('processedVideo').src = `/uploads/${result.filename}`;
            document.getElementById('downloadBtn').href = `/uploads/${result.filename}`;
            document.getElementById('downloadBtn').download = result.filename;
            document.getElementById('resultSection').style.display = 'block';
            
            // التمرير للأسفل لرؤية النتيجة
            document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth' });
        } else {
            alert('حدث خطأ: ' + result.error);
        }
    } catch (error) {
        clearInterval(interval);
        alert('حدث خطأ في الاتصال: ' + error.message);
    } finally {
        btn.disabled = false;
    }
}
